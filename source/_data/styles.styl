body {
    background:url(/images/background.jpg);
    background-repeat: no-repeat;
    background-attachment: fixed; //是否滚动，fixed固定
    background-size: cover;      
    background-position: center;
}

//文章背板的颜色rgb
.main-inner > .sub-menu, .main-inner > .post-block, .main-inner > .tabs-comment, .main-inner > .comments, .main-inner > .pagination{
    background: #f5f5f56b;      //此处使用十六进制颜色代码，         也可以使用rgba进行调色，
                                //实际效果为白色透明色底板              rgba的第四参数即为透明度
}
body{               //修改主体字体颜色
  color: #000;      //纯黑
}
.posts-expand .post-title-link {    //标题颜色
    color: #000;                //首页文章标题颜色， （默认为灰辨识度不高）
}
.posts-expand .post-meta-container {    //标题下的日期颜色
    color: #0eb61c;             //此处修改为红色，可自行调用rgb调色
}

//侧边框的透明度设置
.sidebar {
  opacity: 0.85;
}

//菜单栏的调色
.header-inner {     
  background: rgba(180, 9, 49, 0.45);
}
//搜索框透明
.popup {        
  opacity: 0.5;
}

.main-inner {
    background-color: rgba(255, 255, 255, 0.6);  //主体背景透明
    padding: 0px 40px 40px 40px;  //调整组件位置
}

/* 让所有文章标题变成蓝色 */
.post-title {
  color: #000000;
  font-weight: 600;
}

/* 调整正文字体大小 */
.post-body {
  font-size: 1.1em;
  line-height: 1.8;
}

/* 移除 .brand 的背景块 */
.brand {
  background: none !important;      /* 移除任何背景色或背景图片 */
  border: none !important;          /* 移除边框 */
  box-shadow: none !important;      /* 移除阴影 */
  padding: 0 !important;            /* 如果有内边距导致块状，也去掉 */
  margin: 0 !important;             /* 去掉外边距 */
  display: inline-block;            /* 确保它只占内容大小（如果需要） */
  width: auto;                      /* 宽度自适应 */
  height: auto;                     /* 高度自适应 */
}

/* 网站标题（Valash）字号最大 */
.site-title {
  font-size: 60px !important;   /* 你可以自己调整数值，比如 48px */
}

/* 文章标题字号第二大 */
.post-title-link {
  font-size: 36px !important;   /* 比 site-title 小一点 */
}

/* 设置 .main-inner 背景为半透明暗色 */
.main-inner {
  background-color: rgba(0, 0, 0, 0.8) !important;  /* 黑色半透明，0.7 是不透明度，可调 */
  padding: 20px !important;                         /* 增加内边距，让内容不贴边 */
  border-radius: 8px !important;                    /* 可选：圆角 */
}

/* 调整内部文字颜色为白色，保证在暗色背景上清晰 */
.main-inner,
.main-inner p,
.main-inner li,
.main-inner .post-body {
  color: #fff !important;
}

/* 但链接颜色需要单独处理，避免看不清 */
.main-inner a {
  color: #ffcc00 !important;      /* 设为亮黄色，你可以换其他颜色 */
}
.main-inner a:hover {
  color: #ffaa00 !important;      /* 悬停时颜色变深一点 */
}

/* 让 post-block 背景透明，避免叠加 */
.post-block {
  background: transparent !important;
}

/* 导航栏菜单项链接颜色 */
.menu-item a {
  color: #fff700 !important;  /* 正常状态颜色，这里设为亮黄色，你可以改成你喜欢的 */
}

/* 鼠标悬停时的颜色 */
.menu-item a:hover {
  color: #eb9514 !important;  /* 悬停时颜色加深一点 */
}
